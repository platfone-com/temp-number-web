{
  "name": "temp-number-nodejs-web",
  "version": "2.7.11",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode site",
    "dev-wl": "vite --config src/white-label/vite.config.ts --mode wl",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-wl": "run-p type-check build-only-wl --",
    "preview": "vite preview --port 4173",
    "preview-wl": "vite preview --config src/white-label/vite.config.ts --port 4174",
    "build-only": "vite build",
    "build-only-wl": "vite build --config src/white-label/vite.config.ts",
    "type-check": "vue-tsc --build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "lint-staged": {
    "**/*.{ts,vue}": [
      "eslint . --fix",
      "prettier --write src/"
    ]
  },
  "dependencies": {
    "@stripe/stripe-js": "^6.1.0",
    "@tailwindcss/vite": "4.0.5",
    "axios": "^1.13.0",
    "date-fns": "^4.1.0",
    "firebase": "^11.3.0",
    "pinia": "^2.3.1",
    "tailwindcss": "4.0.5",
    "vee-validate": "^4.15.0",
    "vite-svg-loader": "^5.1.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.5.0",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.10.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.3.0",
    "@vue/tsconfig": "^0.7.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.4.1",
    "eslint": "^9.18.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "jiti": "^2.4.2",
    "lint-staged": "^15.4.3",
    "npm-run-all2": "^7.0.2",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "privatix-prettier": "^1.0.1",
    "typescript": "~5.7.3",
    "vite": "^6.4.1",
    "vite-plugin-csp-guard": "^2.2.0",
    "vite-plugin-vue-devtools": "^7.7.0",
    "vue-tsc": "^2.2.0",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "@tailwindcss/node": "4.0.5",
    "@tailwindcss/oxide": "4.0.5"
  }
}
